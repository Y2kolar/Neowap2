<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>NeoWAP v1.0</title>
    <style>
        body {
            margin: 0; padding: 0; background: #000; color: #0f0; 
            font-family: monospace; font-size: 18px; 
            image-rendering: pixelated;
        }
        .screen {
            max-width: 480px; margin: 20px auto; 
            border: 8px solid #222; background: #001100; 
            padding: 15px; min-height: 80vh;
        }
        .header { text-align: center; color: #0f0; margin-bottom: 20px; }
        .chat { line-height: 1.4; }
        input { 
            width: 100%; background: #000; color: #0f0; 
            border: 2px solid #0f0; padding: 10px; font-family: monospace;
        }
    </style>
</head>
<body>
    <div class="screen">
        <div class="header">=== NEO WAP v2005 ===<br>Мобильный чат 2.0</div>
        <div class="chat" id="chat"></div>
        <input type="text" id="msg" placeholder="Напиши сюда... (как в старом WAP)" onkeypress="if(event.key==='Enter') sendMsg()">
        <button onclick="sendMsg()">Отправить</button>
    </div>

    <script>
        function sendMsg() {
            const input = document.getElementById('msg');
            const chat = document.getElementById('chat');
            if (input.value.trim() === '') return;
            
            chat.innerHTML += `<div><b>Ты:</b> ${input.value}</div>`;
            chat.innerHTML += `<div><b>WAP-Host:</b> Привет! Помнишь ICQ 2005? 😎</div>`;
            input.value = '';
            chat.scrollTop = chat.scrollHeight;
        }
        
        // Приветственное сообщение
        document.getElementById('chat').innerHTML = '<div><b>WAP-Host:</b> Добро пожаловать обратно в 2005-й! Выбери комнату или просто пиши...</div>';
    </script>
</body>
</html>
